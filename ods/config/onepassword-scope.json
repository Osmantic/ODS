{
  "schema_version": 1,
  "selection_rule": "repository-root-then-explicit-namespace",
  "project": {
    "id": "ods",
    "root_selector": "repository-root",
    "workspace": "Osmantic",
    "owners": ["Osmantic maintainers"],
    "allowed_environment_profiles": ["github", "firecrawl"]
  },
  "vault": {
    "name": "Development",
    "id": "dfncpo4o2wrkjf6f3zo6zu35ta",
    "access": "read-only"
  },
  "environment_profiles": {
    "github": {
      "env_file": "${HOME}/.config/platform/environments/github.env",
      "variables": ["GH_TOKEN"],
      "purpose": "Read-only GitHub repository inspection through gh"
    },
    "firecrawl": {
      "env_file": "${HOME}/.config/platform/environments/firecrawl.env",
      "variables": ["FIRECRAWL_API_KEY"],
      "purpose": "Primary-source documentation mapping and scraping"
    }
  },
  "namespaces": [
    {
      "id": "dev",
      "selection": "explicit",
      "vault": {
        "name": "Development",
        "id": "dfncpo4o2wrkjf6f3zo6zu35ta"
      },
      "allowed_environment_profiles": [],
      "validation": ["docker compose config --quiet"]
    },
    {
      "id": "test",
      "selection": "explicit",
      "vault": {
        "name": "Development",
        "id": "dfncpo4o2wrkjf6f3zo6zu35ta"
      },
      "allowed_environment_profiles": [],
      "validation": ["bash ods/tests/test-secret-security.sh"]
    }
  ],
  "prohibitions": [
    "plaintext-secret",
    "repository-op-reference",
    "provider-export",
    "biometric-fallback",
    "unpinned-secret-tool",
    "agent-authored-credential-wrapper",
    "unvalidated-secret-configuration"
  ],
  "validation": [
    "mise exec -- ajv validate --spec=draft2020 -s ods/config/onepassword-scope.schema.json -d ods/config/onepassword-scope.json",
    "git diff --check"
  ]
}
