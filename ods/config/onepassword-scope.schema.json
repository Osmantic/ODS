{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Osmantic/ODS/blob/main/ods/config/onepassword-scope.schema.json",
  "title": "ODS 1Password service-account project scope",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "selection_rule",
    "project",
    "vault",
    "environment_profiles",
    "namespaces",
    "prohibitions",
    "validation"
  ],
  "properties": {
    "schema_version": {"const": 1},
    "selection_rule": {"const": "repository-root-then-explicit-namespace"},
    "project": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "root_selector", "workspace", "owners", "allowed_environment_profiles"],
      "properties": {
        "id": {"const": "ods"},
        "root_selector": {"const": "repository-root"},
        "workspace": {"const": "Osmantic"},
        "owners": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
        "allowed_environment_profiles": {"type": "array", "uniqueItems": true, "items": {"enum": ["github", "firecrawl"]}}
      }
    },
    "vault": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "id", "access"],
      "properties": {
        "name": {"const": "Development"},
        "id": {"const": "dfncpo4o2wrkjf6f3zo6zu35ta"},
        "access": {"const": "read-only"}
      }
    },
    "environment_profiles": {
      "type": "object",
      "additionalProperties": false,
      "required": ["github", "firecrawl"],
      "properties": {
        "github": {"$ref": "#/$defs/githubProfile"},
        "firecrawl": {"$ref": "#/$defs/firecrawlProfile"}
      }
    },
    "namespaces": {
      "type": "array",
      "minItems": 2,
      "maxItems": 2,
      "items": {"$ref": "#/$defs/namespace"}
    },
    "prohibitions": {
      "type": "array",
      "minItems": 7,
      "uniqueItems": true,
      "items": {
        "enum": [
          "plaintext-secret",
          "repository-op-reference",
          "provider-export",
          "biometric-fallback",
          "unpinned-secret-tool",
          "agent-authored-credential-wrapper",
          "unvalidated-secret-configuration"
        ]
      }
    },
    "validation": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1}
    }
  },
  "$defs": {
    "baseProfile": {
      "type": "object",
      "additionalProperties": false,
      "required": ["env_file", "variables", "purpose"],
      "properties": {
        "env_file": {"type": "string", "pattern": "^\\$\\{HOME\\}/\\.config/platform/environments/(github|firecrawl)\\.env$"},
        "variables": {"type": "array", "minItems": 1, "maxItems": 1, "uniqueItems": true, "items": {"type": "string"}},
        "purpose": {"type": "string", "minLength": 1}
      }
    },
    "githubProfile": {
      "allOf": [
        {"$ref": "#/$defs/baseProfile"},
        {"type": "object", "properties": {"env_file": {"const": "${HOME}/.config/platform/environments/github.env"}, "variables": {"const": ["GH_TOKEN"]}}}
      ]
    },
    "firecrawlProfile": {
      "allOf": [
        {"$ref": "#/$defs/baseProfile"},
        {"type": "object", "properties": {"env_file": {"const": "${HOME}/.config/platform/environments/firecrawl.env"}, "variables": {"const": ["FIRECRAWL_API_KEY"]}}}
      ]
    },
    "namespace": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "selection", "vault", "allowed_environment_profiles", "validation"],
      "properties": {
        "id": {"enum": ["dev", "test"]},
        "selection": {"const": "explicit"},
        "vault": {
          "type": "object",
          "additionalProperties": false,
          "required": ["name", "id"],
          "properties": {
            "name": {"const": "Development"},
            "id": {"const": "dfncpo4o2wrkjf6f3zo6zu35ta"}
          }
        },
        "allowed_environment_profiles": {"const": []},
        "validation": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "minLength": 1}}
      }
    }
  }
}
